{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "data/templates.json",
          "assets/**",
          "code.html",
          "admin.html",
          "admin.js",
          "admin.css",
          "script.js",
          "style.css"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
